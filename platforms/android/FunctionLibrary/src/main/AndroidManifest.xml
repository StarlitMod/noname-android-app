<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <queries>
        <package android:name="com.tencent.mobileqq" />
        <package android:name="com.tencent.mm" />
        <package android:name="bin.mt.plus" />
        <package android:name="com.android.chrome" />
        <package android:name="com.android.webview" />
        <package android:name="com.google.android.webview" />
        <package android:name="com.google.android.webview.beta" />
        <package android:name="com.google.android.webview.canary" />
        <package android:name="com.google.android.webview.dev" />
        <package android:name="com.huawei.webview" />
        <package android:name="org.bromite.webview" />
    </queries>
    <application>
        <provider
            android:name="com.widget.noname.CustomDocumentsProvider"
            android:authorities="com.widget.noname.documents"
            android:exported="true"
            android:permission="android.permission.MANAGE_DOCUMENTS"
            android:grantUriPermissions="true">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>
        <service
            android:name="com.widget.noname.CustomService"
            android:authorities="com.widget.noname.CustomService"
            android:process=":remote"
            android:exported="false"
            tools:ignore="Instantiatable" />
        <service
            android:name="com.widget.noname.okhttp.DownloadService"
            android:foregroundServiceType="dataSync"
            android:exported="false"/>
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:exported="true"
            android:label="@string/webview_selection_activity_name"
            android:launchMode="singleTask"
            android:name="com.widget.noname.upgrade.WebViewSelectionActivity"
            android:screenOrientation="fullSensor"
            android:theme="@android:style/Theme.Light.NoTitleBar">
            <intent-filter android:label="@string/launcher_name">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.widget.noname.CrashActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.NoActionBar" />
    </application>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
</manifest>