<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/normal_shadow_style"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/fragment_view_background"
    android:padding="16dp">

    <!-- 扩展名称 - 第一行 -->
    <TextView
        android:id="@+id/extension_name"
        style="@style/normal_shadow_style"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/extension_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 扩展作者 - 第二行 -->
    <LinearLayout
        android:id="@+id/author_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/extension_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/extension_name">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_extension_info_author"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/extension_author"
            style="@style/normal_shadow_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 扩展版本 - 第三行 -->
    <LinearLayout
        android:id="@+id/version_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/extension_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/author_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_extension_info_version"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/extension_version"
            style="@style/normal_shadow_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 扩展介绍 - 第四行 -->
    <LinearLayout
        android:id="@+id/intro_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/extension_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/version_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_extension_info_intro"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/extension_intro"
            style="@style/normal_shadow_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 下载地址 - 第五行 -->
    <LinearLayout
        android:id="@+id/disk_url_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/extension_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/intro_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_extension_info_download"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/extension_disk_url"
            style="@style/normal_shadow_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:textSize="14sp"
            android:clickable="true"/>
    </LinearLayout>

    <!-- 论坛地址 - 第六行 -->
    <LinearLayout
        android:id="@+id/forum_url_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@+id/extension_switch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/disk_url_container">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_extension_info_forum"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/extension_forum_url"
            style="@style/normal_shadow_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:focusable="true"
            android:textSize="14sp"
            android:clickable="true"/>
    </LinearLayout>

    <!-- 启用开关 - 右上角 -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/extension_switch"
        style="@style/normal_shadow_style"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumb="@drawable/selector_thumb"
        app:track="@drawable/selector_track"
        app:showText="true"
        android:textOn="开"
        android:textOff="关"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 删除按钮 - 右下角 -->
    <Button
        android:id="@+id/remove_button"
        style="@style/normal_shadow_style"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/common_action_delete"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
