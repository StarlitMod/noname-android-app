<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <import type="com.widget.noname.function.functionversion.subfragment.AssetFragment" />
        <import type="com.widget.noname.function.functionversion.databinding.AssetFragmentData" />
        <import type="android.widget.RadioGroup.OnCheckedChangeListener" />
        <import type="android.view.View" />
        <variable name="data" type="com.widget.noname.function.functionversion.databinding.AssetFragmentData" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp"
        tools:ignore="HardcodedText">

        <TextView
            android:id="@+id/tv_asset_path"
            style="@style/asset_fragment_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{@string/common_resource_path + data.assetPath}" />

        <TextView
            style="@style/asset_fragment_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{@string/common_resource_version + data.version}" />

        <TextView
            style="@style/asset_fragment_text_style"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@{@string/common_resource_size + (data.assetSize ?? @string/common_progress_loading)}" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fragment_view_background"
            android:orientation="vertical"
            android:padding="10dp">

            <RadioGroup
                android:id="@+id/radio_group_update"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/asset_fragment_text_style"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_resource_update_source" />

                <RadioButton
                    android:id="@+id/ratio_button_github"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="@{AssetFragment.DEFAULT_UPDATE_URL_GITHUB.equals(data.updateUri)}"
                    android:text="@{data.configName}" />

<!--                <RadioButton-->
<!--                    android:id="@+id/ratio_button_gitee"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:checked="@{AssetFragment.UPDATE_URL_GITLAB.equals(data.updateUri)}"-->
<!--                    android:text="Gitlab" />-->

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/button_config_update_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_resource_configure_update_source" />

                <CheckBox
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:onCheckedChanged="@{(compoundButton, checked) -> data.setUpdateStatus(checked ? AssetFragmentData.STATUS_CLICK_UPDATE : data.updateStatus)}"
                    android:text="@string/common_resource_force_update"
                    android:checked="@{data.updateStatus != AssetFragmentData.STATUS_NEWEST}"
                    android:visibility="@{data.updateStatus == AssetFragmentData.STATUS_NEWEST ? View.VISIBLE : View.GONE}" />

                <TextView
                    style="@style/asset_fragment_text_style"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{data.downloadProgress}" />

                <Button
                    android:id="@+id/button_click_ask_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="@{data.canUpdate}"
                    android:text="@{data.updateBtnStr}" />
            </RadioGroup>

            <TextView
                style="@style/asset_fragment_text_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:text="@{@string/common_resource_latest_version + data.updateVersion}" />

            <TextView
                android:id="@+id/tv_update_change_log"
                style="@style/asset_fragment_text_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:maxLines="10"
                android:scrollbars="vertical"
                android:text="@{@string/common_resource_release_notes + data.updateChangeLog}" />

        </LinearLayout>

    </LinearLayout>
</layout>